---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const hydraSrc = `${base}/hydra/index.html`;

const featured = (await getCollection('works', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
---

<Base>
  <!-- ===== HERO: HYDRA(署名オブジェクト) ===== -->
  <section class="hero">
    <iframe
      id="hydra"
      class="hero-bg"
      src={hydraSrc}
      title="Hayashi Design Works — Hydra"
      aria-hidden="true"
      tabindex="-1"
      scrolling="no"
      loading="eager"></iframe>

    <div class="hero-meta wrap">
      <h1 class="hero-name">Soki Hayashi</h1>
      <span>Graphic · Branding · 3DCG</span>
    </div>

    <div class="scroll-cue" aria-hidden="true"><span>Scroll</span></div>
  </section>

  <script>
    // タップ=分裂 / 水平ドラッグ=スワイプカット を HYDRA に転送。
    // iframeは pointer-events:none のままなので、縦スクロールは一切邪魔しない。
    function initHeroTap() {
      const hero = document.querySelector('.hero') as HTMLElement | null;
      const frame = document.getElementById('hydra') as HTMLIFrameElement | null;
      if (!hero || !frame || hero.dataset.bound) return;
      hero.dataset.bound = '1';

      const send = (msg: any) => frame.contentWindow?.postMessage(msg, '*');
      const norm = (e: { clientX: number; clientY: number }) => {
        const r = hero.getBoundingClientRect();
        return { x: (e.clientX - r.left) / r.width, y: (e.clientY - r.top) / r.height };
      };

      let last: { x: number; y: number } | null = null;
      let moved = false;

      hero.addEventListener('pointerdown', (e) => {
        last = norm(e as PointerEvent);
        moved = false;
      });
      hero.addEventListener('pointermove', (e) => {
        const pe = e as PointerEvent;
        if (pe.pointerType === 'mouse' && pe.buttons === 0) {
          last = null;
          return;
        }
        const p = norm(pe);
        if (last) {
          const dx = p.x - last.x;
          const dy = p.y - last.y;
          if (Math.abs(dx) > 0.012 || Math.abs(dy) > 0.012) moved = true;
          // 水平ドラッグのみスワイプ転送(縦はページスクロールに任せる)
          if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 0.004) {
            send({ hdwSwipe: { dx, dy } });
          }
        }
        last = p;
      });
      hero.addEventListener('pointerup', () => (last = null));
      hero.addEventListener('pointercancel', () => (last = null));

      hero.addEventListener('click', (e) => {
        if (moved) {
          moved = false;
          return;
        } // ドラッグ後のクリックは無視
        send({ hdwPoke: norm(e as MouseEvent) });
      });
    }
    document.addEventListener('astro:page-load', initHeroTap);
  </script>

  <!-- ===== FEATURED WORKS ===== -->
  <section class="featured wrap">
    <h2 class="section-label" data-reveal>Selected Works</h2>
    <ul class="grid">
      {
        featured.map((w) => (
          <li class="card" data-reveal>
            <a href={w.data.url ?? '#'} class="card-link">
              <div
                class="thumb"
                style={`--accent:${w.data.accent}`}
                aria-hidden="true"
              />
              <div class="meta">
                <h3 class="card-title">{w.data.title}</h3>
                <p class="card-sub">
                  {w.data.role.join(' / ')}
                  {w.data.year ? ` — ${w.data.year}` : ''}
                </p>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
    <p class="more" data-reveal>
      <a href={`${base}/works`}>View all works →</a>
    </p>
  </section>
</Base>

<style>
  .hero {
    position: relative;
    height: 100svh;
    min-height: 560px;
    overflow: hidden;
    background: #000;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
    /* 生のタッチ/クリックを HYDRA に直接通す(Wixと同じ=何度でも弾ける) */
    pointer-events: auto;
  }
  /* Heroは液体が主役。文字は隅に最小限。 */
  .hero-name {
    margin: 0;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: inherit;
  }
  .hero-meta {
    position: absolute;
    left: 0;
    right: 0;
    bottom: clamp(2.5rem, 7vh, 4.5rem);
    z-index: 2;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    pointer-events: none;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(244, 241, 234, 0.7);
  }
  .scroll-cue {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    bottom: 1.6rem;
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
    animation: cue 2.4s ease-in-out infinite;
  }
  @keyframes cue {
    0%,
    100% {
      opacity: 0.35;
      transform: translate(-50%, 0);
    }
    50% {
      opacity: 1;
      transform: translate(-50%, 4px);
    }
  }

  .featured {
    padding-block: clamp(4rem, 12vh, 9rem);
  }
  .more {
    margin-top: clamp(2rem, 5vh, 3.5rem);
    font-size: 0.95rem;
  }
  .more a {
    color: var(--accent);
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s;
  }
  .more a:hover {
    border-color: var(--accent);
  }
</style>
