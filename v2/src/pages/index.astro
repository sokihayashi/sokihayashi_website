---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const hydraSrc = `${base}/hydra/index.html`;

const featured = (await getCollection('works', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
---

<Base>
  <!-- ===== HERO: HYDRA(署名オブジェクト) ===== -->
  <section class="hero">
    <iframe
      id="hydra"
      class="hero-bg"
      src={hydraSrc}
      title="Hayashi Design Works — Hydra"
      aria-hidden="true"
      tabindex="-1"
      scrolling="no"
      loading="eager"></iframe>

    <div class="hero-stage">
      <h1 class="hero-head">Design across<br />dimensions.</h1>
    </div>

    <div class="hero-meta wrap" aria-hidden="true">
      <span>Soki Hayashi</span>
      <span>Graphic · Branding · 3DCG</span>
    </div>

    <div class="scroll-cue" aria-hidden="true"><span>Scroll</span></div>
  </section>

  <script>
    // タップ/クリックを HYDRA に転送(iframeは pointer-events:none のまま
    // なので、ページのスクロールは一切邪魔しない)
    function initHeroTap() {
      const hero = document.querySelector('.hero');
      const frame = document.getElementById('hydra') as HTMLIFrameElement | null;
      if (!hero || !frame) return;
      hero.addEventListener('click', (e) => {
        const ev = e as MouseEvent;
        const r = (hero as HTMLElement).getBoundingClientRect();
        const x = (ev.clientX - r.left) / r.width;
        const y = (ev.clientY - r.top) / r.height;
        frame.contentWindow?.postMessage({ hdwPoke: { x, y } }, '*');
      });
    }
    document.addEventListener('astro:page-load', initHeroTap);
  </script>

  <!-- ===== FEATURED WORKS ===== -->
  <section class="featured wrap">
    <h2 class="section-label" data-reveal>Selected Works</h2>
    <ul class="grid">
      {
        featured.map((w) => (
          <li class="card" data-reveal>
            <a href={w.data.url ?? '#'} class="card-link">
              <div
                class="thumb"
                style={`--accent:${w.data.accent}`}
                aria-hidden="true"
              />
              <div class="meta">
                <h3 class="card-title">{w.data.title}</h3>
                <p class="card-sub">
                  {w.data.role.join(' / ')}
                  {w.data.year ? ` — ${w.data.year}` : ''}
                </p>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
    <p class="more" data-reveal>
      <a href={`${base}/works`}>View all works →</a>
    </p>
  </section>
</Base>

<style>
  .hero {
    position: relative;
    height: 100svh;
    min-height: 560px;
    overflow: hidden;
    background: #000;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
    pointer-events: none;
  }
  @media (hover: hover) and (pointer: fine) {
    .hero-bg {
      pointer-events: auto;
    }
  }
  /* 巨大見出しを HYDRA に重ねて融合(henriheymans方式) */
  .hero-stage {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: grid;
    place-items: center;
    padding: var(--pad);
    pointer-events: none;
  }
  .hero-head {
    margin: 0;
    text-align: center;
    font-weight: 800;
    font-size: clamp(2.8rem, 11vw, 9rem);
    line-height: 0.88;
    letter-spacing: -0.04em;
    color: var(--fg);
    text-shadow: 0 2px 50px rgba(0, 0, 0, 0.4);
  }
  .hero-meta {
    position: absolute;
    left: 0;
    right: 0;
    bottom: clamp(2.5rem, 7vh, 4.5rem);
    z-index: 2;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    pointer-events: none;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(244, 241, 234, 0.7);
  }
  .scroll-cue {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    bottom: 1.6rem;
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
    animation: cue 2.4s ease-in-out infinite;
  }
  @keyframes cue {
    0%,
    100% {
      opacity: 0.35;
      transform: translate(-50%, 0);
    }
    50% {
      opacity: 1;
      transform: translate(-50%, 4px);
    }
  }

  .featured {
    padding-block: clamp(4rem, 12vh, 9rem);
  }
  .more {
    margin-top: clamp(2rem, 5vh, 3.5rem);
    font-size: 0.95rem;
  }
  .more a {
    color: var(--accent);
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s;
  }
  .more a:hover {
    border-color: var(--accent);
  }
</style>
