---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const hydraSrc = `${base}/hydra/index.html`;

const featured = (await getCollection('works', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
---

<Base>
  <!-- ===== HERO: HYDRA(署名オブジェクト) ===== -->
  <section class="hero">
    <iframe
      class="hero-bg"
      src={hydraSrc}
      title="Hayashi Design Works — Hydra"
      aria-hidden="true"
      tabindex="-1"
      scrolling="no"
      loading="eager"></iframe>

    <div class="hero-copy wrap">
      <p class="eyebrow">Designer — Graphic / Branding / 3DCG</p>
      <h1 class="hero-title">Design across<br />dimensions.</h1>
      <p class="hero-lede">平面から立体まで、領域をまたいで設計する。</p>
    </div>

    <div class="scroll-cue" aria-hidden="true"><span>Scroll</span></div>
  </section>

  <!-- ===== FEATURED WORKS ===== -->
  <section class="featured wrap">
    <h2 class="section-label" data-reveal>Selected Works</h2>
    <ul class="grid">
      {
        featured.map((w) => (
          <li class="card" data-reveal>
            <a href={w.data.url ?? '#'} class="card-link">
              <div
                class="thumb"
                style={`--accent:${w.data.accent}`}
                aria-hidden="true"
              />
              <div class="meta">
                <h3 class="card-title">{w.data.title}</h3>
                <p class="card-sub">
                  {w.data.role.join(' / ')}
                  {w.data.year ? ` — ${w.data.year}` : ''}
                </p>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
    <p class="more" data-reveal>
      <a href={`${base}/works`}>View all works →</a>
    </p>
  </section>
</Base>

<style>
  .hero {
    position: relative;
    height: 100svh;
    min-height: 560px;
    overflow: hidden;
    background: #000;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
    pointer-events: none;
  }
  @media (hover: hover) and (pointer: fine) {
    .hero-bg {
      pointer-events: auto;
    }
  }
  .hero-copy {
    position: absolute;
    left: 0;
    right: 0;
    bottom: clamp(4rem, 12vh, 8rem);
    max-width: 24ch;
  }
  .hero-title {
    margin: 0;
    font-size: clamp(2.4rem, 7vw, 5.5rem);
    line-height: 0.98;
    font-weight: 700;
    letter-spacing: -0.03em;
  }
  .hero-lede {
    margin: 1.2rem 0 0;
    color: rgba(244, 241, 234, 0.8);
    font-size: clamp(0.95rem, 1.3vw, 1.1rem);
  }
  .scroll-cue {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    bottom: 1.6rem;
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
    animation: cue 2.4s ease-in-out infinite;
  }
  @keyframes cue {
    0%,
    100% {
      opacity: 0.35;
      transform: translate(-50%, 0);
    }
    50% {
      opacity: 1;
      transform: translate(-50%, 4px);
    }
  }

  .featured {
    padding-block: clamp(4rem, 12vh, 9rem);
  }
  .more {
    margin-top: clamp(2rem, 5vh, 3.5rem);
    font-size: 0.95rem;
  }
  .more a {
    color: var(--accent);
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s;
  }
  .more a:hover {
    border-color: var(--accent);
  }
</style>
