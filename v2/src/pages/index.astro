---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const works = (await getCollection('works', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);

// GitHub Pages の base を考慮して HYDRA(静的アセット)を参照
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const hydraSrc = `${base}/hydra/index.html`;
---

<Base>
  <!-- ===== HERO: HYDRA(署名オブジェクト) ===== -->
  <section class="hero">
    <iframe
      class="hero-bg"
      src={hydraSrc}
      title="Hayashi Design Works — Hydra"
      aria-hidden="true"
      tabindex="-1"
      scrolling="no"
      loading="eager"></iframe>

    <div class="hero-chrome">
      <header class="site-head">
        <span class="logo">Soki&nbsp;Hayashi</span>
        <nav class="nav">
          <a href="#works">Works</a>
          <a href="#about">About</a>
          <a href="#contact">Contact</a>
        </nav>
      </header>

      <div class="hero-copy">
        <p class="eyebrow">Designer — Graphic / Branding / 3DCG</p>
        <h1 class="hero-title">Design across dimensions.</h1>
        <p class="hero-lede">平面から立体まで、領域をまたいで設計する。</p>
      </div>

      <div class="scroll-cue" aria-hidden="true">
        <span>Scroll</span>
      </div>
    </div>
  </section>

  <!-- ===== WORKS ===== -->
  <section id="works" class="works wrap">
    <h2 class="section-label" data-reveal>Selected Works</h2>
    <ul class="grid">
      {
        works.map((w) => (
          <li class="card" data-reveal>
            <a href={w.data.url ?? '#'} class="card-link">
              <div
                class="thumb"
                style={`--accent:${w.data.accent}`}
                aria-hidden="true"
              />
              <div class="meta">
                <h3 class="card-title">{w.data.title}</h3>
                <p class="card-sub">
                  {w.data.role.join(' / ')}
                  {w.data.year ? ` — ${w.data.year}` : ''}
                </p>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- ===== ABOUT ===== -->
  <section id="about" class="about wrap">
    <h2 class="section-label" data-reveal>About</h2>
    <p class="about-text" data-reveal>
      ここにプロフィール文が入ります。Markdownや本文はあとから差し替え可能。<br />
      実績が増えたら <code>src/content/works/</code> に .md を足すだけで一覧に反映されます。
    </p>
  </section>

  <!-- ===== CONTACT(暫定) ===== -->
  <section id="contact" class="contact wrap">
    <h2 class="section-label" data-reveal>Contact</h2>
    <p class="about-text" data-reveal>
      お問い合わせフォームはこの後実装します。<br />
      （名前 / 会社名 / メール / ご相談内容 など）
    </p>
  </section>

  <footer class="site-foot wrap">
    <span>© {new Date().getFullYear()} Soki Hayashi</span>
  </footer>
</Base>

<style>
  /* ===== HERO ===== */
  .hero {
    position: relative;
    height: 100svh;
    min-height: 560px;
    overflow: hidden;
    background: #000;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
    /* v1は装飾として表示(スクロールを邪魔しない)。
       次パスでインタラクション/ジャイロを安全に再有効化する。 */
    pointer-events: none;
  }
  .hero-chrome {
    position: relative;
    z-index: 2;
    height: 100%;
    display: grid;
    grid-template-rows: auto 1fr auto;
    padding: var(--pad);
    /* テキスト可読性のための控えめなスクリム */
    background:
      radial-gradient(120% 80% at 20% 90%, rgba(0, 0, 0, 0.5), transparent 60%),
      linear-gradient(to bottom, rgba(0, 0, 0, 0.35), transparent 22%);
  }

  .site-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo {
    font-weight: 700;
    letter-spacing: 0.02em;
  }
  .nav a {
    margin-left: 1.5rem;
    color: var(--muted);
    font-size: 0.9rem;
    transition: color 0.3s;
  }
  .nav a:hover {
    color: var(--fg);
  }

  .hero-copy {
    align-self: end;
    max-width: 24ch;
  }
  .eyebrow {
    margin: 0 0 0.9rem;
    font-size: 0.8rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .hero-title {
    margin: 0;
    font-size: clamp(2.4rem, 7vw, 5.5rem);
    line-height: 0.98;
    font-weight: 700;
    letter-spacing: -0.03em;
  }
  .hero-lede {
    margin: 1.2rem 0 0;
    color: rgba(244, 241, 234, 0.8);
    font-size: clamp(0.95rem, 1.3vw, 1.1rem);
  }
  .scroll-cue {
    justify-self: center;
    align-self: end;
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
    animation: cue 2.4s ease-in-out infinite;
  }
  @keyframes cue {
    0%, 100% { opacity: 0.35; transform: translateY(0); }
    50% { opacity: 1; transform: translateY(4px); }
  }

  /* ===== SECTIONS ===== */
  .section-label {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--muted);
    font-weight: 500;
    border-top: 1px solid var(--line);
    padding-top: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .works {
    padding-block: clamp(4rem, 12vh, 9rem);
  }
  .grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: clamp(1.5rem, 3vw, 3rem) clamp(1.5rem, 2.5vw, 2.5rem);
  }
  .card-link {
    display: block;
  }
  .thumb {
    aspect-ratio: 4 / 5;
    border-radius: 4px;
    background: linear-gradient(
      150deg,
      var(--accent),
      color-mix(in srgb, var(--accent) 55%, #000)
    );
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .card-link:hover .thumb {
    transform: translateY(-6px) scale(1.01);
  }
  .meta {
    padding-top: 1rem;
  }
  .card-title {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
  }
  .card-sub {
    margin: 0.35rem 0 0;
    font-size: 0.85rem;
    color: var(--muted);
  }

  .about,
  .contact {
    padding-block: clamp(3rem, 9vh, 7rem);
  }
  .about-text {
    max-width: 52ch;
    font-size: clamp(1.1rem, 2vw, 1.6rem);
    line-height: 1.7;
  }
  .about-text code {
    font-size: 0.85em;
    color: var(--accent);
  }

  .site-foot {
    padding-block: 3rem;
    color: var(--muted);
    font-size: 0.85rem;
    border-top: 1px solid var(--line);
  }
</style>
