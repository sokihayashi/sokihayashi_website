---
import Base from '../layouts/Base.astro';
---

<Base title="Contact — Soki Hayashi">
  <section class="page wrap">
    <p class="eyebrow" data-reveal>Get in touch</p>
    <h1 class="page-title" data-reveal>Contact</h1>

    <p class="prose" data-reveal>
      お仕事のご相談・お見積もり、お気軽にどうぞ。<br />
      （フォームはこの後に実装します。名前 / 会社名 / メール / ご相談内容 など。）
    </p>

    <p class="prose" data-reveal style="margin-top:2rem">
      <a
        href="mailto:soki.haya@gmail.com"
        style="color:var(--accent); border-bottom:1px solid var(--accent)"
        >soki.haya@gmail.com →</a
      >
    </p>
  </section>
</Base>
